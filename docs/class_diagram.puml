@startuml NTA_English_ClassDiagram

title Biểu đồ Class - Hệ thống Quản lý Trung tâm Tiếng Anh NTA

skinparam classAttributeIconSize 0
skinparam class {
  BackgroundColor #DDEEFF
  BorderColor #2563EB
  ArrowColor #374151
  HeaderBackgroundColor #2563EB
  HeaderFontColor #FFFFFF
}

' ==================== NGƯỜI DÙNG ====================
