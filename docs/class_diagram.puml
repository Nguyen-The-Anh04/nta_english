' ==================== RELATIONSHIPS ====================

' Người dùng - phân quyền
NguoiDung "1" -- "1" ChucVu : có >
note on link: {unique: email}\n{unique: sdt}

' Khoá học & Lớp học
KhoaHoc "1" -- "0..*" LopHoc : chứa >
KhoaHoc "1" -- "1..*" ChiTietKhoaHoc : có nội dung >
note on link: {ordered: so_thu_tu}
LopHoc "1" -- "1..*" BuoiHoc : có buổi học >
LopHoc "1" -- "0..*" LichHoc : có lịch >
LopHoc "0..*" -- "1" PhongHoc : học tại >
note on link: {constraint: si_so_hien_tai <= PhongHoc.suc_chua}
LopHoc "0..*" -- "1" NguoiDung : giảng dạy bởi >
note on link: {constraint: NguoiDung.chuc_vu = 'giao_vien'}

' Đăng ký học viên vào lớp (bảng trung gian nhiều-nhiều)
NguoiDung "1" -- "0..*" DangKyLopHoc : đăng ký >
note on link: {constraint: NguoiDung.chuc_vu = 'hoc_vien'}
LopHoc "1" -- "0..*" DangKyLopHoc : có >
note on link: {constraint: si_so_hien_tai < si_so_toi_da}
DangKyLopHoc "1" -- "0..*" DiemDanh : điểm danh >

' Bài tập
LopHoc "1" -- "0..*" BaiTap : có >
BaiTap "1" -- "0..*" NopBai : nhận >
NguoiDung "1" -- "0..*" NopBai : nộp >
note on link: {constraint: ngay_nop <= BaiTap.han_nop}

' Bài test
Lead "1" -- "0..*" LichHenTest : hẹn test >
NguoiDung "1" -- "0..*" LichHenTest : tham gia >
NguoiDung "1" -- "0..*" BaiTest : làm >
BaiTest "1" -- "0..*" KetQuaTest : có kết quả >
note on link: {ordered: loai_ky_nang}

' Tài chính
NguoiDung "1" -- "0..*" HopDong : ký >
KhoaHoc "1" -- "0..*" HopDong : thuộc >
note on link: {constraint: tong_tien = KhoaHoc.hoc_phi}
HopDong "1" -- "0..*" PhieuThu : thanh toán qua >
note on link: {constraint: SUM(PhieuThu.tong_tien) <= HopDong.tong_tien}
NguoiDung "1" -- "0..*" PhieuThu : nộp >
NguoiDung "1" -- "0..*" PhieuChi : nhận >

' Sách & Kho
LoaiSach "1" -- "0..*" Sach : phân loại >
NhaCungCap "1" -- "0..*" Sach : cung cấp >
NhaCungCap "1" -- "0..*" HoaDonNhap : cung cấp >
HoaDonNhap "1" -- "1..*" ChiTietHoaDonNhap : gồm >
ChiTietHoaDonNhap "0..*" -- "1" Sach : nhập >
note on link: {constraint: cập nhật Sach.so_luong_ton += so_luong}

' Đơn hàng bán
DonHang "1" -- "1..*" ChiTietDonHang : gồm >
ChiTietDonHang "0..*" -- "1" Sach : mua >
note on link: {constraint: Sach.so_luong_ton >= so_luong}
NguoiDung "1" -- "0..*" DonHang : đặt >

' Lead
NguoiDung "1" -- "0..*" Lead : quản lý >
note on link: {constraint: NguoiDung.chuc_vu = 'nhan_vien_kd'}

' Affiliate
NguoiDung "1" -- "0..1" CTV : là >
CTV "1" -- "0..*" HoaHong : nhận >
DonHang "1" -- "0..*" HoaHong : tạo ra >
note on link: {constraint: chỉ tạo khi DonHang.trang_thai = 'da_giao'}
CTV "1" -- "0..*" RutTien : yêu cầu >
note on link: {constraint: so_tien <= CTV.tong_hoa_hong}

' Thông báo
NguoiDung "1" -- "0..*" ThongBao : gửi/nhận >

@enduml
